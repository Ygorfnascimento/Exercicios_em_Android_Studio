<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textview_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Olá, Nome e Sobrenome" />

    <TextView
        android:id="@+id/textview_learn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/textview_name"
        android:layout_marginTop="16dp"
        android:text="O que vamos aprender hoje?"
        android:textStyle="bold"
        android:textSize="22sp" />

    <ImageView
        android:id="@+id/image_development"
        android:layout_width="128dp"
        android:layout_height="160dp"
        android:layout_below="@id/textview_learn"
        android:layout_alignParentStart="true"
        android:layout_marginTop="32dp"
        android:contentDescription="Desenvolvimento"
        android:src="@drawable/image_development" />

    <ImageView
        android:id="@+id/image_explore"
        android:layout_width="128dp"
        android:layout_height="160dp"
        android:layout_below="@id/image_development"
        android:layout_alignParentStart="true"
        android:layout_marginTop="32dp"
        android:contentDescription="Explorar"
        android:src="@drawable/image_explore" />

    <ImageView
        android:id="@+id/image_design"
        android:layout_width="128dp"
        android:layout_height="160dp"
        android:layout_below="@id/textview_learn"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="32dp"
        android:contentDescription="Design"
        android:src="@drawable/image_design" />

    <ImageView
        android:id="@+id/image_ai"
        android:layout_width="128dp"
        android:layout_height="160dp"
        android:layout_below="@id/image_design"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="32dp"
        android:contentDescription="Inteligência Artificial"
        android:src="@drawable/image_ai" />

    <TextView
        android:id="@+id/textview_popular_courses"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/image_explore"
        android:layout_marginTop="32dp"
        android:text="Cursos populares" />

    <TextView
        android:id="@+id/textview_see_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/textview_popular_courses"
        android:layout_alignParentEnd="true"
        android:text="Ver todos"
        android:textStyle="bold" />

    <View
        android:id="@+id/view_background"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_below="@id/textview_popular_courses"
        android:layout_marginTop="8dp"
        android:background="@drawable/image_background" />

    <TextView
        android:id="@+id/textview_android"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_alignTop="@id/view_background"
        android:layout_alignBottom="@id/view_background"
        android:layout_marginStart="16dp"
        android:gravity="center_vertical"
        android:text="Desenvolvimento Android"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/image_android"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignTop="@+id/view_background"
        android:layout_alignBottom="@+id/view_background"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_android" />

</RelativeLayout>